# =============================================================================
# Wan 2.6 Video Generator - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# STEP 1: Get your fal.ai API key at https://fal.ai/dashboard/keys
# =============================================================================

# --- fal.ai API ---
FAL_API_KEY=your_fal_api_key_here

# --- PostgreSQL Database ---
POSTGRES_DB=wan_videos
POSTGRES_USER=wan_user
POSTGRES_PASSWORD=change_me_in_production

# --- Backend ---
# These are already set in docker-compose.yml but can be overridden here
SPRING_PROFILES_ACTIVE=docker
SERVER_PORT=8080

# --- Frontend ---
VITE_API_BASE_URL=http://localhost:8080
